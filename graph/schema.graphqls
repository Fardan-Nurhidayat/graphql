type Query {
  todos: [Todo!]!
  todo(id: ID!): Todo
  todoByStatus(done: Boolean!): [Todo!]!
}

type Mutation {
  createTodo(input: NewTodo!): Todo!
  updateTodo(id: ID!, input: UpdateTodo!): Todo!
  deleteTodo(id: ID!): Boolean!
  toggleTodo(id: ID!): Todo!
}

type Todo {
  id: ID!
  text: String!
  done: Boolean!
  createdAt: String!
}

input NewTodo {
  text: String!
}

input UpdateTodo {
  text: String
  done: Boolean
}
